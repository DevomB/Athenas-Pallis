# .vscode/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets & local env (never commit keys)
.env
.env.*
!.env.example

# Logs & coverage
*.log
coverage/
lcov.info
tarpaulin-report.*

# Debug / profiling
*.dSYM/
perf.data*

# Temporary / scratch
*.tmp
*.temp
.cache/
